# ════════════════════════════════════════════════════
# 텔레그램 봇 환경변수 예시
# ════════════════════════════════════════════════════
# 이 파일은 자리표시자만 들어있는 예시입니다.
# 실제 값은 .env 파일에 넣고, .env는 절대 git에 커밋하지 마세요.
# (.gitignore에 .env가 이미 등록되어 있음)
# ════════════════════════════════════════════════════

# ─── 텔레그램 봇 ────────────────────────────────────
# BotFather에서 발급받은 토큰
TELEGRAM_TOKEN=your_bot_token_here

# ─── Supabase ──────────────────────────────────────
# Supabase Dashboard → Settings → API 에서 확인
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ─── Webhook (Cloud Run 배포 시) ────────────────────
# 봇이 배포된 Cloud Run URL + /webhook 경로
WEBHOOK_URL=https://your-service-xxxxx.run.app/webhook

# 🆕 Webhook 비밀 토큰 (C12 보안 — 32자 무작위 권장)
#   생성 방법: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET_TOKEN=

# ─── Cloud Scheduler 인증 ────────────────────────────
# 스케줄러 트리거 호출 시 검증할 토큰 (무작위 32자 권장)
SCHEDULER_TOKEN=your_random_scheduler_token_here
BROADCAST_TOKEN=your_random_broadcast_token_here

# ─── 미니앱 / 대시보드 ───────────────────────────────
MINIAPP_URL=
DASHBOARD_URL=https://your-dashboard-url/

# ─── 주간 알림 시각 (옵션, 기본 19:00) ───────────────
WEEKLY_REMINDER_HOUR=19
WEEKLY_REMINDER_MIN=0

# ─── 🆕 첫 관리자 부트스트랩 (C4 보안, 1회만 사용) ──
# 봇 처음 가동할 때만 활성. 첫 관리자 등록 후엔 무시됨.
BOOTSTRAP_ADMIN_USER_ID=

# 비상 복구용 — 마지막 관리자가 lockout 됐을 때 .env로 권한 복원
EMERGENCY_ADMIN_USER_ID=

# ─── 🆕 교회 목록 (C10 외부화, 쉼표 구분) ───────────
# 예: CHURCH_LIST=서울교회,포천교회,구리교회
CHURCH_LIST=
